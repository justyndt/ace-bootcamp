# Ignore everything in the root except the "wp-content", ".gitignore" and "README.md" directory.
/*
!.gitignore
!wp-content/
!README.md

# Ignore everything in the "wp-content" directory, except the "themes" directories.
wp-content/*

# Optionally exclude all WordPress' "twenty" themes
wp-content/themes/twenty*/

# Include the "themes" folder
!wp-content/themes/
wp-content/index.php
wp-content/themes/index.php

# Include mu-plugins file tprt-wpcli.php
!wp-content/mu-plugins/
wp-content/mu-plugins/*
!wp-content/mu-plugins/tprt-wpcli.php

# From WP ENgine, large/disallowed file types, a CDN should be used for these
*.hqx
*.bin
*.exe
*.dll
